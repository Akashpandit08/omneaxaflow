# =============================================================================
# AiVideo — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
ENVIRONMENT=development           # development | staging | production
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=aivideo
POSTGRES_PASSWORD=aivideo_secret
POSTGRES_DB=aivideo
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://aivideo:aivideo_secret@db:5432/aivideo

# -----------------------------------------------------------------------------
# REDIS (Cache + Celery Broker)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=another-long-random-secret-for-jwt
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# AWS S3
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=aivideo-media
S3_PRESIGNED_URL_EXPIRY=3600   # seconds

# -----------------------------------------------------------------------------
# STRIPE (Subscriptions)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id

# -----------------------------------------------------------------------------
# ELEVENLABS (Voice Generation)
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# -----------------------------------------------------------------------------
# NEXT.JS (Frontend — must be prefixed NEXT_PUBLIC_ to expose to browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
